{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "npm run build"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindowMs": 60000,
    "startCommand": "npm run start"
  },
  "plugins": {
    "postgres": {
      "version": "15"
    }
  }
}
