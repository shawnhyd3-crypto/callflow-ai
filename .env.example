# Database
# Prisma uses POSTGRES_PRISMA_URL. DATABASE_URL is accepted as a fallback.
POSTGRES_PRISMA_URL="postgresql://user:password@localhost:5432/callflow_ai"
DATABASE_URL="postgresql://user:password@localhost:5432/callflow_ai"

# Authentication
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Vapi Configuration
VAPI_API_KEY="your-vapi-api-key"
VAPI_WEBHOOK_SECRET="your-vapi-webhook-secret"

# Stripe Configuration
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"
STRIPE_WEBHOOK_SECRET="whsec_your_stripe_webhook_secret"

# Stripe Product IDs (create these in Stripe Dashboard)
STRIPE_STARTER_PRICE_ID="price_starter_monthly"
STRIPE_PRO_PRICE_ID="price_pro_monthly"
STRIPE_BUSINESS_PRICE_ID="price_business_monthly"

# Analytics
ESTIMATED_APPOINTMENT_VALUE_CENTS="25000"

# App URL (used for Stripe portal return URL)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
